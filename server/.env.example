# JWT Secret Key
# Gere uma chave segura aleatória usando: openssl rand -base64 32
# NUNCA compartilhe este valor ou faça commit do arquivo .env
JWT_SECRET=your_super_secret_key_here_generate_a_random_one

# Porta do servidor (opcional, padrão é 8001)
PORT=8001

# Configurações do PostgreSQL
# Desenvolvimento: geralmente localhost
# Produção: host do servidor de banco de dados
DB_HOST=localhost
DB_PORT=5432
DB_NAME=alya
DB_USER=postgres
DB_PASSWORD=postgres

# URL do Frontend (usada para gerar o link no e-mail)
VITE_API_URL=http://localhost:8000

# Node Environment
NODE_ENV=development

# CORS Origins (separados por vírgula)
# Adicione as origens permitidas separadas por vírgula
CORS_ORIGINS=https://seudominio.com,http://localhost:8000,http://localhost:5173

# Configurações do SendGrid (Recuperação de Senha)
# Obtenha sua API Key em: https://app.sendgrid.com/settings/api_keys
# SENDGRID_API_KEY=SG.sua_api_key_aqui
# SENDGRID_FROM_EMAIL=naoresponder@seudominio.com.br
# SENDGRID_FROM_NAME=Seu Sistema
# ALERT_EMAIL_FROM=security@seudominio.com  # Deve ser verificado no SendGrid
# ALERT_EMAIL_TO=admin@seudominio.com,outro-admin@empresa.com  # Múltiplos emails separados por vírgula

# Encryption at Rest (LGPD Compliance)
# Gere chaves usando: node scripts/generate-encryption-key.js
# IMPORTANTE: Use chaves diferentes em dev/staging/produção
# Rotacione a cada 90 dias usando reEncrypt() em utils/encryption.js
ENCRYPTION_KEY=gerar-com-generate-encryption-key.js
ENCRYPTION_SALT=gerar-com-generate-encryption-key.js

# Anomaly Detection Thresholds
MAX_REQUESTS_PER_MINUTE=60
MAX_FAILED_LOGINS_PER_HOUR=10
MAX_COUNTRIES_PER_DAY=3
MAX_IPS_PER_DAY=5
MAX_SESSIONS_PER_USER=5
UNUSUAL_HOUR_START=2
UNUSUAL_HOUR_END=6
Z_SCORE_THRESHOLD=2.5
ANOMALY_MONITORING_INTERVAL=15