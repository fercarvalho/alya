# JWT Secret Key
# Gere uma chave segura aleatória usando: openssl rand -base64 32
# NUNCA compartilhe este valor ou faça commit do arquivo .env
JWT_SECRET=your_super_secret_key_here_generate_a_random_one

# Porta do servidor (opcional, padrão é 8001)
PORT=8001

# Configurações do PostgreSQL
# Desenvolvimento: geralmente localhost
# Produção: host do servidor de banco de dados
DB_HOST=localhost
DB_PORT=5432
DB_NAME=alya
DB_USER=postgres
DB_PASSWORD=postgres

# URL do Frontend (usada para gerar o link no e-mail)
VITE_API_URL=http://localhost:8000

# Node Environment
NODE_ENV=development

# CORS Origins (separados por vírgula)
# Adicione as origens permitidas separadas por vírgula
CORS_ORIGINS=https://seudominio.com,http://localhost:8000,http://localhost:5173

# Configurações do SendGrid (Recuperação de Senha)
# Obtenha sua API Key em: https://app.sendgrid.com/settings/api_keys
# SENDGRID_API_KEY=SG.sua_api_key_aqui
# SENDGRID_FROM_EMAIL=naoresponder@seudominio.com.br
# SENDGRID_FROM_NAME=Seu Sistema
