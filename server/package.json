{
  "name": "alya-api",
  "version": "1.0.0",
  "description": "Backend API for Alya Financial System",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "migrate": "node migrate-to-postgresql.js",
    "migrate-projection": "node migrate-projection-to-postgresql.js",
    "validate-migration": "node validate-migration.js",
    "validate-projection-migration": "node validate-projection-migration.js",
    "backup-json": "node backup-json-data.js",
    "cleanup-json": "node cleanup-json-files.js",
    "fix-dates": "node fix-transaction-dates.js",
    "create-security-tables": "psql -U seuusuario -d alya -h localhost -f \"migrations/003 - SEGURANCA.sql\"",
    "audit-logs": "node view-audit-logs.js",
    "audit-logs:recent": "node view-audit-logs.js recent",
    "audit-logs:failures": "node view-audit-logs.js failures",
    "audit-logs:suspicious": "node view-audit-logs.js suspicious",
    "audit-logs:stats": "node view-audit-logs.js stats",
    "archive-logs": "node archive-audit-logs.js",
    "archive-logs:dry-run": "node archive-audit-logs.js --dry-run",
    "archive-logs:90d": "node archive-audit-logs.js --days=90",
    "archive-logs:180d": "node archive-audit-logs.js --days=180",
    "archive-logs:1y": "node archive-audit-logs.js --days=365",
    "security:audit": "npm audit --production",
    "security:fix": "npm audit fix",
    "security:check": "npm outdated && npm audit",
    "security:full-scan": "npm audit && npm outdated"
  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.6",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.3.1",
    "geoip-lite": "^1.4.10",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.11.3",
    "sanitize-html": "^2.17.2",
    "ua-parser-js": "^2.0.9",
    "xlsx": "^0.18.5",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
